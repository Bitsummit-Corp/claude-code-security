{
  "permissions": {
    "deny": [
      {
        "pattern": "Bash(printenv *)",
        "threat": "T-001-secret-leak"
      },
      {
        "pattern": "Bash(env)",
        "threat": "T-001-secret-leak"
      },
      {
        "pattern": "Bash(security find-generic-password *)",
        "threat": "T-001-secret-leak"
      },
      {
        "pattern": "Read(/Users/x/.ssh/**)",
        "threat": "T-003-credential-exfil"
      },
      {
        "pattern": "Read(/Users/x/.aws/credentials)",
        "threat": "T-003-credential-exfil"
      },
      {
        "pattern": "Read(/Users/x/.gnupg/**)",
        "threat": "T-003-credential-exfil"
      },
      {
        "pattern": "Bash(rm -rf /)",
        "threat": "T-002-destructive-fs"
      },
      {
        "pattern": "Bash(rm -rf /*)",
        "threat": "T-002-destructive-fs"
      },
      {
        "pattern": "Bash(rm -rf /Users/x)",
        "threat": "T-002-destructive-fs"
      },
      {
        "pattern": "Bash(rm -rf ~)",
        "threat": "T-002-destructive-fs"
      },
      {
        "pattern": "Bash(mkfs *)",
        "threat": "T-002-destructive-fs"
      },
      {
        "pattern": "Bash(dd * of=/dev/*)",
        "threat": "T-002-destructive-fs"
      },
      {
        "pattern": "Bash(shred -u *)",
        "threat": "T-002-destructive-fs"
      },
      {
        "pattern": "Bash(git push --force *)",
        "threat": "T-004-branch-sabotage"
      },
      {
        "pattern": "Bash(git push -f *)",
        "threat": "T-004-branch-sabotage"
      },
      {
        "pattern": "Read(/Users/x/.kube/**)",
        "threat": "T-003-credential-exfil"
      },
      {
        "pattern": "Read(/Users/x/.docker/config.json)",
        "threat": "T-003-credential-exfil"
      },
      {
        "pattern": "Read(/Users/x/.netrc)",
        "threat": "T-003-credential-exfil"
      },
      {
        "pattern": "Read(/Users/x/.config/gh/hosts.yml)",
        "threat": "T-003-credential-exfil"
      },
      {
        "pattern": "Read(/etc/sudoers)",
        "threat": "T-003-credential-exfil"
      },
      {
        "pattern": "Read(/etc/sudoers.d/**)",
        "threat": "T-003-credential-exfil"
      },
      {
        "pattern": "Bash(curl * | sh)",
        "threat": "T-006-pipe-to-shell"
      },
      {
        "pattern": "Bash(curl * | bash)",
        "threat": "T-006-pipe-to-shell"
      },
      {
        "pattern": "Bash(wget * | sh)",
        "threat": "T-006-pipe-to-shell"
      },
      {
        "pattern": "Bash(wget * | bash)",
        "threat": "T-006-pipe-to-shell"
      },
      {
        "pattern": "Bash(git filter-branch *)",
        "threat": "T-008-history-rewrite"
      },
      {
        "pattern": "Bash(git filter-repo *)",
        "threat": "T-008-history-rewrite"
      },
      {
        "pattern": "Edit(*.gitmodules)",
        "threat": "T-005-supply-chain-submodule"
      },
      {
        "pattern": "Write(*.gitmodules)",
        "threat": "T-005-supply-chain-submodule"
      }
    ],
    "allow": []
  },
  "hooks": {
    "PreToolUse": [
      {
        "name": "secret-guard"
      },
      {
        "name": "keychain-guard"
      },
      {
        "name": "mcp-secret-guard"
      },
      {
        "name": "destructive-fs-guard"
      },
      {
        "name": "git-destructive-guard"
      },
      {
        "name": "sensitive-paths-guard"
      },
      {
        "name": "dotfile-guard"
      },
      {
        "name": "bash-structural-guard"
      },
      {
        "name": "pipe-to-shell-guard"
      },
      {
        "name": "branch-protection-guard"
      },
      {
        "name": "commit-amend-pushed-guard"
      },
      {
        "name": "submodule-injection-guard"
      },
      {
        "name": "git-history-rewrite-guard"
      }
    ],
    "PostToolUse": [
      {
        "name": "secret-leak-detector"
      }
    ],
    "UserPromptSubmit": [],
    "SessionStart": []
  },
  "schema": 1,
  "ccsec_version": "0.1.0-alpha.0",
  "audit": {
    "log_path": "${HOME}/.claude/ccsec-audit.jsonl"
  }
}
